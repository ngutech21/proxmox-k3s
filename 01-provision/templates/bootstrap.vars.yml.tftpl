k3s_version: "${k3s_version}"
api_endpoint: "${api_endpoint}"
kubeconfig: "~/.kube/config.new"
cluster_context: "proxmox-k3s"
kube_vip_version: "${kube_vip_version}"
kube_vip_cloud_provider_version: "${kube_vip_cloud_provider_version}"
kube_vip_service_range: "${kube_vip_service_range}"
extra_server_args: >-
  --disable traefik
  --disable servicelb
  --tls-san ${api_endpoint}
  --node-taint node-role.kubernetes.io/control-plane=true:NoSchedule
