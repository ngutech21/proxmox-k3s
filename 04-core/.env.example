# Internal DNS suffix used for ingress hosts
DOMAIN_SUFFIX=k3s.home

# Optional override. Defaults to longhorn.${DOMAIN_SUFFIX}
# LONGHORN_HOST=longhorn.k3s.home

# Optional override. Defaults to smoke.${DOMAIN_SUFFIX}
# CERT_MANAGER_SMOKE_HOST=smoke.k3s.home

# cert-manager issuer naming
CERT_MANAGER_SELFSIGNED_ISSUER=selfsigned-bootstrap
CERT_MANAGER_CA_ISSUER=homelab-ca
CERT_MANAGER_ROOT_CERT=homelab-root-ca
CERT_MANAGER_ROOT_SECRET=homelab-root-ca-key-pair

# Optional smoke test certificate
CERT_MANAGER_ENABLE_SMOKE_TEST=false
